# Get your project ID from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional: comma-separated RPC fallbacks per chain.
# The app will try these first, then fall back to the chain's built-in public RPC.
# Example:
# VITE_RPC_URL_MAINNET=https://eth.llamarpc.com,https://ethereum-rpc.publicnode.com
# VITE_RPC_URL_SEPOLIA=https://ethereum-sepolia-rpc.publicnode.com
VITE_RPC_URL_MAINNET=
VITE_RPC_URL_SEPOLIA=
VITE_RPC_URL_ARBITRUM=
VITE_RPC_URL_OPTIMISM=
VITE_RPC_URL_POLYGON=
VITE_RPC_URL_BASE=
VITE_RPC_URL_GNOSIS=
